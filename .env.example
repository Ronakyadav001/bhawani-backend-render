NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yoga_wellness?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/yoga_wellness?schema=public
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*

# Optional integrations. Keep disabled until real keys are available.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
FCM_PROJECT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Zoom Server-to-Server OAuth credentials.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Web redirects and CORS used by Flutter/admin/website navigation.
# In production, set CORS_ORIGIN to approved domains only, for example:
# CORS_ORIGIN=https://bhawanifitness.com,https://admin.bhawanifitness.com
SUPPORT_CHAT_URL=https://support.example.com/chat
SALES_PANEL_URL=https://admin.example.com/sales
TRAINER_PANEL_URL=https://admin.example.com/trainer
DIETICIAN_PANEL_URL=https://admin.example.com/dietician
SUPPORT_PANEL_URL=https://admin.example.com/support
SUPPORT_HOURS=10:00-19:00 IST
